// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`renderCodexSkill > matches snapshot for a representative skill with sidecar > sidecar 1`] = `
"interface:
  display_name: Snap
  short_description: Snapshot blurb
  brand_color: "#00ccff"
policy:
  allow_implicit_invocation: true
dependencies:
  tools:
    - fs
    - web
"
`;

exports[`renderCodexSkill > matches snapshot for a representative skill with sidecar > skillMd 1`] = `
"---
name: snap-skill
description: Snapshot fixture skill.
allowed-tools: Bash Read
license: MIT
metadata:
  short-description: Snapshot blurb
---
Use gpt-5.4 for synthesis.
"
`;
